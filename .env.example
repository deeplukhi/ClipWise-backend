NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/clipwise?schema=public
CORS_ORIGIN=http://localhost:3001
LOG_LEVEL=debug

# OpenRouter API Key — get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free

# Redis (for background job queue)
REDIS_HOST=localhost
REDIS_PORT=6379
